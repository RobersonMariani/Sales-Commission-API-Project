includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
    level: 5
    ignoreErrors:
        # Mockery fluent methods not recognized by PHPStan
        -
            message: '#Call to an undefined method Mockery\\ExpectationInterface\|Mockery\\HigherOrderMessage::#'
            path: app/Api/Modules/*/Tests/*
        # JWT guard login() returns token string, not void like StatefulGuard
        -
            message: '#Result of method Illuminate\\Contracts\\Auth\\StatefulGuard::login\(\) \(void\) is used#'
            path: app/Api/Modules/*/Tests/*
